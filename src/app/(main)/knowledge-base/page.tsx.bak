"use client";
import React, { useState } from "react";
import {
  BookOpen, Plus, Search, Settings, Upload, Download, Trash2, Eye, FileText,
  ChevronRight, ChevronDown, Database, Cpu, Zap, Layers, RefreshCw,
  X, CheckCircle2, AlertCircle, Tag, ArrowRight, Play, Pause, Link2,
  BarChart3, MessageSquare, ToggleLeft, ToggleRight, FileUp, EyeOff
} from "lucide-react";
import toast from "react-hot-toast";

interface KnowledgeBase {
  id: string;
  name: string;
  type: "knowledge_graph" | "vector" | "hybrid";
  doc_count: number;
  chunk_count: number;
  embedding_model: string;
  status: "active" | "building" | "error";
  created_at: string;
  size: string;
  description: string;
}

interface VectorDataset {
  id: string;
  name: string;
  file: string;
  format: string;
  size: string;
  chunk_count: number;
  indexed_at: string;
}

const MOCK_KB: KnowledgeBase[] = [
  { id: "kb1", name: "产品知识库", type: "hybrid", doc_count: 2840, chunk_count: 12450, embedding_model: "BGE-M3", status: "active", created_at: "2025-04-10", size: "128 MB", description: "公司产品文档、技术规格、用户手册的完整知识库" },
  { id: "kb2", name: "客服知识库", type: "vector", doc_count: 1560, chunk_count: 8320, embedding_model: "BGE-M3", status: "active", created_at: "2025-04-08", size: "64 MB", description: "常见问题解答、客服话术、投诉处理流程" },
  { id: "kb3", name: "内部制度知识图谱", type: "knowledge_graph", doc_count: 420, chunk_count: 2100, embedding_model: "BGE-M3", status: "building", created_at: "2025-04-15", size: "18 MB", description: "公司组织架构、岗位职责、制度流程的知识图谱" },
  { id: "kb4", name: "技术文档库", type: "vector", doc_count: 980, chunk_count: 5600, embedding_model: "BGE-M3", status: "active", created_at: "2025-04-05", size: "45 MB", description: "API文档、开发指南、架构设计文档" },
];

const MOCK_VECTORS: VectorDataset[] = [
  { id: "vd1", name: "产品手册向量集", file: "product_manual.pdf", format: "PDF", size: "128 MB", chunk_count: 12450, indexed_at: "2025-04-10" },
  { id: "vd2", name: "客服问答向量集", file: "qa_corpus.json", format: "JSON", size: "64 MB", chunk_count: 8320, indexed_at: "2025-04-08" },
  { id: "vd3", name: "API文档向量集", file: "api_docs.md", format: "Markdown", size: "45 MB", chunk_count: 5600, indexed_at: "2025-04-05" },
];

const EMBEDDING_MODELS = [
  { value: "bge-m3", label: "BGE-M3 (推荐)", desc: "支持100+语言，稠密+稀疏混合检索" },
  { value: "text2vec", label: "Text2Vec", desc: "中文语义相似度模型" },
  { value: "m3e", label: "M3E", desc: "开源中文Embedding模型" },
];
const CHUNK_METHODS = ["段落切分", "句子切分", "滑动窗口", "语义切分", "自定义规则"];

export default function KnowledgeBasePage() {
  const [tab, setTab] = useState<"kb" | "vector" | "test" | "files">("kb");
  const [search, setSearch] = useState("");
  const [kbList, setKbList] = useState<KnowledgeBase[]>(MOCK_KB);
  const [showCreate, setShowCreate] = useState(false);
  const [createStep, setCreateStep] = useState(1);
  const [createConfig, setCreateConfig] = useState({
    name: "", description: "", type: "vector" as "vector" | "knowledge_graph" | "hybrid",
    embedding_model: "bge-m3", chunk_method: "段落切分", chunk_size: 500, chunk_overlap: 50,
    use_rerank: true, rerank_model: "bge-reranker", use_kg: false,
    pdf_parser: "默认解析器", tags: [] as string[],
  });
  const [testQuery, setTestQuery] = useState("");
  const [testResults, setTestResults] = useState<any[]>([]);
  const [testLoading, setTestLoading] = useState(false);
  const [testKg, setTestKg] = useState(false);
  const [rerankToggle, setRerankToggle] = useState(true);

  const filtered = kbList.filter(k => !search || k.name.includes(search) || k.description.includes(search));

  const updateConfig = (k: string, v: any) => setCreateConfig(prev => ({ ...prev, [k]: v }));

  const createKb = () => {
    if (!createConfig.name) { toast.error("请填写知识库名称"); return; }
    const kb: KnowledgeBase = {
      id: "kb" + Date.now(), ...createConfig, doc_count: 0, chunk_count: 0, status: "building",
      created_at: new Date().toLocaleDateString("zh-CN"), size: "0 MB",
    };
    setKbList(prev => [kb, ...prev]);
    setShowCreate(false);
    setCreateStep(1);
    setCreateConfig({ name: "", description: "", type: "vector", embedding_model: "bge-m3", chunk_method: "段落切分", chunk_size: 500, chunk_overlap: 50, use_rerank: true, rerank_model: "bge-reranker", use_kg: false, pdf_parser: "默认解析器", tags: [] });
    toast.success("知识库创建任务已提交，正在构建中...");
  };

  const runTest = async () => {
    if (!testQuery) { toast.error("请输入测试文本"); return; }
    setTestLoading(true);
    await new Promise(r => setTimeout(r, 1500));
    setTestResults([
      { content: "根据产品手册第3.2节，该产品支持的最大分辨率为3840x2160，帧率可达60fps。", score: 0.94, source: "产品知识库", page: "P.45" },
      { content: "产品规格表显示，该设备支持4K HDMI输入接口，兼容HDCP 2.2协议。", score: 0.87, source: "技术文档库", page: "P.12" },
      { content: "FAQ问答集：关于4K分辨率的常见问题，请参考第8章 Troubleshooting 部分。", score: 0.82, source: "客服知识库", page: "Q&A #156" },
      { content: "API开发文档中关于分辨率设置的接口说明：setResolution(width, height)。", score: 0.76, source: "技术文档库", page: "API #3.1.2" },
    ]);
    setTestLoading(false);
  };

  const statusColor = (s: string) => s === "active" ? "#16a34a" : s === "building" ? "#2563eb" : "#dc2626";

  return (
    <main style={{ flex: 1, overflowY: "auto", background: "#f8fafc", minHeight: "100vh" }}>
      <div style={{ padding: "24px 32px 0", background: "#f8fafc" }}>
        <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 20 }}>
          <div style={{ width: 40, height: 40, borderRadius: 10, background: "#f59e0b", display: "flex", alignItems: "center", justifyContent: "center" }}>
            <BookOpen size={20} color="#fff" />
          </div>
          <div>
            <h1 style={{ fontSize: 20, fontWeight: 700, color: "#1e293b", margin: 0 }}>向量知识库</h1>
            <p style={{ fontSize: 12, color: "#94a3b8", margin: "2px 0 0 0" }}>RAG知识库 · 检索增强生成 · 知识图谱</p>
          </div>
          <div style={{ marginLeft: "auto" }}>
            <button onClick={() => setShowCreate(true)} style={{ display: "flex", alignItems: "center", gap: 5, padding: "7px 14px", borderRadius: 7, border: "none", background: "#f59e0b", color: "#fff", fontSize: 12, fontWeight: 600, cursor: "pointer" }}>
              <Plus size={13} />新建知识库
            </button>
          </div>
        </div>
        <div style={{ display: "flex", gap: 4, borderBottom: "2px solid #e2e8f0", marginBottom: 20 }}>
          {[{ key: "kb", label: "知识库管理", icon: BookOpen }, { key: "vector", label: "向量数据集", icon: Database }, { key: "test", label: "检索测试", icon: Search }, { key: "files", label: "文件管理", icon: FileUp }].map(t => {
            const Icon = t.icon;
            const isActive = tab === t.key;
            return (
              <button key={t.key} onClick={() => setTab(t.key as any)}
                style={{ display: "flex", alignItems: "center", gap: 6, padding: "10px 16px", border: "none", background: "transparent", borderBottom: `2px solid ${isActive ? "#f59e0b" : "transparent"}`, color: isActive ? "#f59e0b" : "#64748b", fontSize: 13, fontWeight: isActive ? 600 : 400, cursor: "pointer", marginBottom: -2 }}>
                <Icon size={14} />{t.label}
              </button>
            );
          })}
        </div>
      </div>

      <div style={{ padding: "0 32px 32px" }}>
        {tab === "kb" && (
          <div>
            {!showCreate && (
              <>
                <div style={{ background: "#fff", border: "1px solid #e2e8f0", borderRadius: 10, padding: "14px 20px", marginBottom: 16 }}>
                  <div style={{ position: "relative", flex: 1 }}>
                    <Search size={13} style={{ position: "absolute", left: 10, top: "50%", transform: "translateY(-50%)", color: "#94a3b8" }} />
                    <input value={search} onChange={e => setSearch(e.target.value)} placeholder="搜索知识库名称或描述"
                      style={{ width: "100%", height: 34, paddingLeft: 32, paddingRight: 10, borderRadius: 6, border: "1px solid #e2e8f0", fontSize: 12, outline: "none", background: "#f8fafc", boxSizing: "border-box" }} />
                  </div>
                </div>
                <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(320px, 1fr))", gap: 16 }}>
                  {filtered.map(kb => (
                    <div key={kb.id} style={{ background: "#fff", border: "1px solid #e2e8f0", borderRadius: 10, padding: 18, transition: "box-shadow 0.15s" }}
                      onMouseEnter={e => (e.currentTarget.style.boxShadow = "0 4px 16px rgba(0,0,0,0.08)")}
                      onMouseLeave={e => (e.currentTarget.style.boxShadow = "none")}
                    >
                      <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 10 }}>
                        <div style={{ flex: 1 }}>
                          <div style={{ display: "flex", alignItems: "center", gap: 6, marginBottom: 4 }}>
                            <span style={{ fontSize: 14, fontWeight: 700, color: "#1e293b" }}>{kb.name}</span>
                            <span style={{ fontSize: 10, padding: "1px 6px", borderRadius: 4, background: `${statusColor(kb.status)}15`, color: statusColor(kb.status), fontWeight: 600 }}>
                              {kb.status === "active" ? "运行中" : kb.status === "building" ? "构建中" : "异常"}
                            </span>
                          </div>
                          <div style={{ display: "flex", gap: 8, fontSize: 10, color: "#94a3b8" }}>
                            <span>{kb.type === "hybrid" ? "混合" : kb.type === "knowledge_graph" ? "知识图谱" : "向量检索"}</span>
                            <span>·</span>
                            <span>嵌入: {kb.embedding_model}</span>
                          </div>
                        </div>
                      </div>
                      <p style={{ fontSize: 12, color: "#64748b", margin: "0 0 12px 0", lineHeight: 1.6 }}>{kb.description}</p>
                      <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 8, marginBottom: 12 }}>
                        {[
                          { label: "文档", value: kb.doc_count.toLocaleString() },
                          { label: "切片", value: kb.chunk_count.toLocaleString() },
                          { label: "大小", value: kb.size },
                          { label: "创建", value: kb.created_at },
                        ].map(m => (
                          <div key={m.label} style={{ background: "#f8fafc", borderRadius: 5, padding: "6px 8px", textAlign: "center" }}>
                            <div style={{ fontSize: 14, fontWeight: 700, color: "#1e293b" }}>{m.value}</div>
                            <div style={{ fontSize: 10, color: "#94a3b8" }}>{m.label}</div>
                          </div>
                        ))}
                      </div>
                      <div style={{ display: "flex", gap: 6, paddingTop: 10, borderTop: "1px solid #f1f5f9" }}>
                        <button style={{ flex: 1, padding: "5px", borderRadius: 5, border: "1px solid #e2e8f0", background: "#fff", cursor: "pointer", fontSize: 11, color: "#64748b", display: "flex", alignItems: "center", justifyContent: "center", gap: 3 }}>
                          <Eye size={11} />查看
                        </button>
                        <button style={{ flex: 1, padding: "5px", borderRadius: 5, border: "1px solid #e2e8f0", background: "#fff", cursor: "pointer", fontSize: 11, color: "#64748b", display: "flex", alignItems: "center", justifyContent: "center", gap: 3 }}>
                          <Settings size={11} />配置
                        </button>
                        <button style={{ flex: 1, padding: "5px", borderRadius: 5, border: "1px solid #fecaca", background: "#fff", cursor: "pointer", fontSize: 11, color: "#dc2626", display: "flex", alignItems: "center", justifyContent: "center", gap: 3 }}>
                          <Trash2 size={11} />删除
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              </>
            )}

            {showCreate && (
              <div style={{ background: "#fff", border: "1px solid #e2e8f0", borderRadius: 10, padding: 28, position: "relative" }}>
                <button onClick={() => { setShowCreate(false); setCreateStep(1); }} style={{ position: "absolute", top: 16, right: 16, padding: "6px 10px", borderRadius: 6, border: "1px solid #e2e8f0", background: "#fff", cursor: "pointer", fontSize: 12, color: "#64748b" }}>x 关闭</button>
                <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 24 }}>
                  {["基础信息", "RAG配置", "切片与嵌入", "确认创建"].map((s, i) => {
                    const n = i + 1;
                    const isDone = createStep > n;
                    const isActive = createStep === n;
                    return (
                      <React.Fragment key={s}>
                        <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
                          <div style={{ width: 24, height: 24, borderRadius: "50%", background: isDone ? "#16a34a" : isActive ? "#f59e0b" : "#e2e8f0", color: isDone || isActive ? "#fff" : "#94a3b8", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 11, fontWeight: 700 }}>{isDone ? "OK" : n}</div>
                          <span style={{ fontSize: 12, fontWeight: isActive ? 600 : 400, color: isDone || isActive ? "#1e293b" : "#94a3b8" }}>{s}</span>
                        </div>
                        {i < 3 && <div style={{ flex: 1, height: 2, background: isDone ? "#bbf7d0" : "#e2e8f0", margin: "0 12px" }} />}
                      </React.Fragment>
                    );
                  })}
                </div>

                {createStep === 1 && (
                  <div>
                    <div style={{ marginBottom: 16 }}>
                      <label style={{ fontSize: 12, fontWeight: 600, color: "#64748b", display: "block", marginBottom: 6 }}>知识库名称 *</label>
                      <input value={createConfig.name} onChange={e => updateConfig("name", e.target.value)} placeholder="例如: 产品知识库"
                        style={{ width: "100%", height: 36, padding: "0 12px", borderRadius: 6, border: "1px solid #e2e8f0", fontSize: 13, outline: "none" }} />
                    </div>
                    <div style={{ marginBottom: 16 }}>
                      <label style={{ fontSize: 12, fontWeight: 600, color: "#64748b", display: "block", marginBottom: 6 }}>描述</label>
                      <input value={createConfig.description} onChange={e => updateConfig("description", e.target.value)} placeholder="简要描述知识库用途"
                        style={{ width: "100%", height: 36, padding: "0 12px", borderRadius: 6, border: "1px solid #e2e8f0", fontSize: 13, outline: "none" }} />
                    </div>
                    <div style={{ marginBottom: 16 }}>
                      <label style={{ fontSize: 12, fontWeight: 600, color: "#64748b", display: "block", marginBottom: 8 }}>知识库类型</label>
                      <div style={{ display: "flex", gap: 10 }}>
                        {[{ label: "向量检索", value: "vector" }, { label: "知识图谱", value: "knowledge_graph" }, { label: "混合模式", value: "hybrid" }].map(t => (
                          <div key={t.value} onClick={() => updateConfig("type", t.value)}
                            style={{ flex: 1, padding: "12px", borderRadius: 7, border: `1px solid ${createConfig.type === t.value ? "#f59e0b" : "#e2e8f0"}`, background: createConfig.type === t.value ? "#fffbeb" : "#fff", cursor: "pointer", textAlign: "center" }}>
                            <div style={{ fontSize: 12, fontWeight: createConfig.type === t.value ? 600 : 400, color: createConfig.type === t.value ? "#d97706" : "#1e293b" }}>{t.label}</div>
                          </div>
                        ))}
                      </div>
                    </div>
                    <button onClick={() => { if (!createConfig.name) { toast.error("请填写名称"); return; } setCreateStep(2); }}
                      style={{ padding: "9px 24px", borderRadius: 7, border: "none", background: "#f59e0b", color: "#fff", fontSize: 13, fontWeight: 600, cursor: "pointer" }}>下一步</button>
                  </div>
                )}
                {createStep === 2 && (
                  <div>
                    <div style={{ display: "flex", gap: 16, marginBottom: 16, alignItems: "center" }}>
                      <div onClick={() => setRerankToggle(!rerankToggle)} style={{ display: "flex", alignItems: "center", gap: 8, cursor: "pointer" }}>
                        {rerankToggle ? <ToggleRight size={22} color="#f59e0b" /> : <ToggleLeft size={22} color="#94a3b8" />}
                        <span style={{ fontSize: 13, color: "#334155" }}>启用 Rerank 重排</span>
                      </div>
                    </div>
                    {rerankToggle && (
                      <div style={{ marginBottom: 16, padding: 14, background: "#f8fafc", borderRadius: 8 }}>
                        <label style={{ fontSize: 12, fontWeight: 600, color: "#64748b", display: "block", marginBottom: 6 }}>Rerank 模型</label>
                        <select value={createConfig.rerank_model} onChange={e => updateConfig("rerank_model", e.target.value)}
                          style={{ width: "100%", height: 34, padding: "0 10px", borderRadius: 6, border: "1px solid #e2e8f0", fontSize: 12, outline: "none", background: "#fff" }}>
                          <option>bge-reranker-v2</option><option>bge-reranker-large</option>
                        </select>
                      </div>
                    )}
                    <div style={{ display: "flex", gap: 10 }}>
                      <button onClick={() => setCreateStep(1)} style={{ padding: "9px 20px", borderRadius: 7, border: "1px solid #e2e8f0", background: "#fff", color: "#64748b", fontSize: 13, cursor: "pointer" }}>上一步</button>
                      <button onClick={() => setCreateStep(3)} style={{ padding: "9px 24px", borderRadius: 7, border: "none", background: "#f59e0b", color: "#fff", fontSize: 13, fontWeight: 600, cursor: "pointer" }}>下一步</button>
                    </div>
                  </div>
                )}
                {createStep === 3 && (
                  <div>
                    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 16, marginBottom: 16 }}>
                      <div>
                        <label style={{ fontSize: 12, fontWeight: 600, color: "#64748b", display: "block", marginBottom: 6 }}>嵌入模型</label>
                        <select value={createConfig.embedding_model} onChange={e => updateConfig("embedding_model", e.target.value)}
                          style={{ width: "100%", height: 34, padding: "0 10px", borderRadius: 6, border: "1px solid #e2e8f0", fontSize: 12, outline: "none", background: "#fff" }}>
                          {EMBEDDING_MODELS.map(m => <option key={m.value} value={m.value}>{m.label}</option>)}
                        </select>
                      </div>
                      <div>
                        <label style={{ fontSize: 12, fontWeight: 600, color: "#64748b", display: "block", marginBottom: 6 }}>切片方法</label>
                        <select value={createConfig.chunk_method} onChange={e => updateConfig("chunk_method", e.target.value)}
                          style={{ width: "100%", height: 34, padding: "0 10px", borderRadius: 6, border: "1px solid #e2e8f0", fontSize: 12, outline: "none", background: "#fff" }}>
                          {CHUNK_METHODS.map(m => <option key={m}>{m}</option>)}
                        </select>
                      </div>
                      <div>
                        <label style={{ fontSize: 12, fontWeight: 600, color: "#64748b", display: "block", marginBottom: 6 }}>切片大小 (字符)</label>
                        <input type="number" value={createConfig.chunk_size} onChange={e => updateConfig("chunk_size", Number(e.target.value))}
                          style={{ width: "100%", height: 34, padding: "0 10px", borderRadius: 6, border: "1px solid #e2e8f0", fontSize: 12, outline: "none", background: "#f8fafc" }} />
                      </div>
                      <div>
                        <label style={{ fontSize: 12, fontWeight: 600, color: "#64748b", display: "block", marginBottom: 6 }}>切片重叠 (字符)</label>
                        <input type="number" value={createConfig.chunk_overlap} onChange={e => updateConfig("chunk_overlap", Number(e.target.value))}
                          style={{ width: "100%", height: 34, padding: "0 10px", borderRadius: 6, border: "1px solid #e2e8f0", fontSize: 12, outline: "none", background: "#f8fafc" }} />
                      </div>
                    </div>
                    <div style={{ display: "flex", gap: 10 }}>
                      <button onClick={() => setCreateStep(2)} style={{ padding: "9px 20px", borderRadius: 7, border: "1px solid #e2e8f0", background: "#fff", color: "#64748b", fontSize: 13, cursor: "pointer" }}>上一步</button>
                      <button onClick={() => setCreateStep(4)} style={{ padding: "9px 24px", borderRadius: 7, border: "none", background: "#f59e0b", color: "#fff", fontSize: 13, fontWeight: 600, cursor: "pointer" }}>下一步</button>
                    </div>
                  </div>
                )}
                {createStep === 4 && (
                  <div>
                    <h3 style={{ fontSize: 14, fontWeight: 600, color: "#1e293b", marginBottom: 16 }}>确认知识库配置</h3>
                    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10, marginBottom: 20 }}>
                      {[
                        { label: "名称", value: createConfig.name }, { label: "类型", value: createConfig.type === "hybrid" ? "混合模式" : createConfig.type === "knowledge_graph" ? "知识图谱" : "向量检索" },
                        { label: "嵌入模型", value: EMBEDDING_MODELS.find(m => m.value === createConfig.embedding_model)?.label },
                        { label: "切片方法", value: createConfig.chunk_method }, { label: "切片大小", value: createConfig.chunk_size + " 字符" }, { label: "Rerank", value: rerankToggle ? "启用" : "禁用" },
                      ].map(item => (
                        <div key={item.label} style={{ padding: "10px 14px", background: "#f8fafc", borderRadius: 7 }}>
                          <div style={{ fontSize: 11, color: "#94a3b8" }}>{item.label}</div>
                          <div style={{ fontSize: 13, fontWeight: 600, color: "#1e293b", marginTop: 2 }}>{item.value}</div>
                        </div>
                      ))}
                    </div>
                    <div style={{ display: "flex", gap: 10 }}>
                      <button onClick={() => setCreateStep(3)} style={{ flex: 1, padding: "9px", borderRadius: 7, border: "1px solid #e2e8f0", background: "#fff", color: "#64748b", fontSize: 13, cursor: "pointer" }}>修改</button>
                      <button onClick={createKb} style={{ flex: 2, padding: "9px", borderRadius: 7, border: "none", background: "#16a34a", color: "#fff", fontSize: 13, fontWeight: 600, cursor: "pointer", display: "flex", alignItems: "center", justifyContent: "center", gap: 6 }}>
                        <CheckCircle2 size={14} />确认创建知识库
                      </button>
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>
        )}

        {tab === "vector" && (
          <div style={{ background: "#fff", border: "1px solid #e2e8f0", borderRadius: 10, overflow: "hidden" }}>
            <div style={{ padding: "12px 16px", borderBottom: "1px solid #e2e8f0", display: "flex", justifyContent: "space-between", alignItems: "center" }}>
              <div style={{ fontSize: 13, fontWeight: 600, color: "#1e293b" }}>向量数据集列表</div>
              <button style={{ padding: "5px 12px", borderRadius: 5, border: "none", background: "#f59e0b", color: "#fff", fontSize: 11, cursor: "pointer", display: "flex", alignItems: "center", gap: 4 }}>
                <Upload size={11} />导入数据集
              </button>
            </div>
            <table style={{ width: "100%", borderCollapse: "collapse", fontSize: 12 }}>
              <thead><tr style={{ background: "#f8fafc" }}>
                {["数据集名称", "源文件", "格式", "大小", "切片数", "索引时间", "操作"].map(h => (
                  <th key={h} style={{ padding: "9px 14px", textAlign: "left", fontWeight: 600, color: "#64748b", borderBottom: "1px solid #e2e8f0" }}>{h}</th>
                ))}
              </thead>
              <tbody>
                {MOCK_VECTORS.map((vd, i) => (
                  <tr key={vd.id} style={{ background: i % 2 === 1 ? "#fafafa" : "#fff" }}
                    onMouseEnter={e => (e.currentTarget.style.background = "#f0f9ff")}
                    onMouseLeave={e => (e.currentTarget.style.background = i % 2 === 1 ? "#fafafa" : "#fff")}
                  >
                    <td style={{ padding: "10px 14px", fontWeight: 600, color: "#1e293b" }}>{vd.name}</td>
                    <td style={{ padding: "10px 14px", color: "#64748b", fontFamily: "monospace", fontSize: 11 }}>{vd.file}</td>
                    <td style={{ padding: "10px 14px" }}><span style={{ fontSize: 10, padding: "2px 6px", borderRadius: 4, background: "#eff6ff", color: "#2563eb" }}>{vd.format}</span></td>
                    <td style={{ padding: "10px 14px", color: "#64748b" }}>{vd.size}</td>
                    <td style={{ padding: "10px 14px", color: "#64748b" }}>{vd.chunk_count.toLocaleString()}</td>
                    <td style={{ padding: "10px 14px", color: "#94a3b8" }}>{vd.indexed_at}</td>
                    <td style={{ padding: "10px 14px" }}>
                      <div style={{ display: "flex", gap: 4 }}>
                        <button style={{ padding: "4px 7px", borderRadius: 4, border: "1px solid #e2e8f0", background: "#fff", cursor: "pointer" }}><Download size={11} color="#64748b" /></button>
                        <button style={{ padding: "4px 7px", borderRadius: 4, border: "1px solid #fecaca", background: "#fff", cursor: "pointer" }}><Trash2 size={11} color="#dc2626" /></button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        {tab === "test" && (
          <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
            <div style={{ background: "#fff", border: "1px solid #e2e8f0", borderRadius: 10, padding: 24 }}>
              <div style={{ fontSize: 13, fontWeight: 600, color: "#1e293b", marginBottom: 16 }}>检索测试配置</div>
              <div style={{ display: "flex", gap: 16, marginBottom: 16 }}>
                <div style={{ flex: 1 }}>
                  <label style={{ fontSize: 12, fontWeight: 600, color: "#64748b", display: "block", marginBottom: 6 }}>测试文本</label>
                  <textarea value={testQuery} onChange={e => setTestQuery(e.target.value)} placeholder="输入测试查询文本..."
                    rows={3} style={{ width: "100%", padding: "10px 12px", borderRadius: 6, border: "1px solid #e2e8f0", fontSize: 13, outline: "none", resize: "vertical", boxSizing: "border-box", fontFamily: "inherit" }} />
                </div>
                <div style={{ width: 160 }}>
                  <label style={{ fontSize: 12, fontWeight: 600, color: "#64748b", display: "block", marginBottom: 6 }}>Top-K</label>
                  <input type="number" defaultValue={4} style={{ width: "100%", height: 34, padding: "0 10px", borderRadius: 6, border: "1px solid #e2e8f0", fontSize: 12, outline: "none", background: "#f8fafc", marginBottom: 8 }} />
                  <label style={{ fontSize: 12, fontWeight: 600, color: "#64748b", display: "block", marginBottom: 6 }}>知识库</label>
                  <select style={{ width: "100%", height: 34, padding: "0 10px", borderRadius: 6, border: "1px solid #e2e8f0", fontSize: 12, outline: "none", background: "#fff" }}>
                    <option>全部知识库</option><option>产品知识库</option><option>客服知识库</option>
                  </select>
                </div>
              </div>
              <div style={{ display: "flex", gap: 10, alignItems: "center" }}>
                <button onClick={runTest} disabled={testLoading}
                  style={{ height: 36, padding: "0 18px", borderRadius: 6, border: "none", background: testLoading ? "#e2e8f0" : "#f59e0b", color: "#fff", fontSize: 13, fontWeight: 600, cursor: testLoading ? "not-allowed" : "pointer", display: "flex", alignItems: "center", gap: 6 }}>
                  {testLoading ? <><RefreshCw size={13} style={{ animation: "spin 1s linear infinite" }} />检索中...</> : <><Search size={13} />开始检索</>}
                </button>
                <div onClick={() => setTestKg(!testKg)} style={{ display: "flex", alignItems: "center", gap: 6, cursor: "pointer" }}>
                  {testKg ? <ToggleRight size={20} color="#f59e0b" /> : <ToggleLeft size={20} color="#94a3b8" />}
                  <span style={{ fontSize: 12, color: "#334155" }}>启用知识图谱</span>
                </div>
              </div>
            </div>

            {testResults.length > 0 && (
              <div style={{ background: "#fff", border: "1px solid #e2e8f0", borderRadius: 10, padding: 20 }}>
                <div style={{ fontSize: 13, fontWeight: 600, color: "#1e293b", marginBottom: 16 }}>检索结果</div>
                <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
                  {testResults.map((r, i) => (
                    <div key={i} style={{ padding: 14, borderRadius: 8, border: "1px solid #e2e8f0", background: "#f8fafc" }}>
                      <div style={{ display: "flex", justifyContent: "space-between", marginBottom: 6 }}>
                        <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
                          <span style={{ fontSize: 11, fontWeight: 600, color: "#fff", background: "#2563eb", width: 18, height: 18, borderRadius: "50%", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 10 }}>{i + 1}</span>
                          <span style={{ fontSize: 11, color: "#94a3b8" }}>{r.source}</span>
                          <span style={{ fontSize: 10, color: "#94a3b8" }}>{r.page}</span>
                        </div>
                        <span style={{ fontSize: 11, fontWeight: 700, color: "#16a34a" }}>{(r.score * 100).toFixed(0)}%</span>
                      </div>
                      <p style={{ fontSize: 12, color: "#334155", margin: 0, lineHeight: 1.7 }}>{r.content}</p>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        {tab === "files" && (
          <div style={{ background: "#fff", border: "1px solid #e2e8f0", borderRadius: 10, padding: 24 }}>
            <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 16 }}>
              <div style={{ fontSize: 13, fontWeight: 600, color: "#1e293b" }}>知识库文件管理</div>
              <button style={{ padding: "7px 14px", borderRadius: 6, border: "none", background: "#f59e0b", color: "#fff", fontSize: 12, fontWeight: 600, cursor: "pointer", display: "flex", alignItems: "center", gap: 5 }}>
                <Upload size={13} />上传文件
              </button>
            </div>
            <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(200px, 1fr))", gap: 12 }}>
              {[
                { name: "product_manual.pdf", size: "45 MB", type: "PDF", kb: "产品知识库" },
                { name: "api_docs.md", size: "12 MB", type: "Markdown", kb: "技术文档库" },
                { name: "qa_corpus.json", size: "8 MB", type: "JSON", kb: "客服知识库" },
                { name: "internal_policy.pdf", size: "3 MB", type: "PDF", kb: "内部制度知识图谱" },
              ].map(f => (
                <div key={f.name} style={{ border: "1px solid #e2e8f0", borderRadius: 8, padding: 14 }}>
                  <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 8 }}>
                    <FileText size={20} color="#dc2626" />
                    <div style={{ flex: 1, overflow: "hidden" }}>
                      <div style={{ fontSize: 12, fontWeight: 600, color: "#1e293b", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{f.name}</div>
                      <div style={{ fontSize: 10, color: "#94a3b8" }}>{f.size} - {f.type}</div>
                    </div>
                  </div>
                  <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                    <span style={{ fontSize: 10, color: "#64748b", background: "#f8fafc", padding: "1px 6px", borderRadius: 3 }}>{f.kb}</span>
                    <div style={{ display: "flex", gap: 4 }}>
                      <button style={{ background: "none", border: "none", cursor: "pointer", padding: 2 }}><Download size={13} color="#64748b" /></button>
                      <button style={{ background: "none", border: "none", cursor: "pointer", padding: 2 }}><Trash2 size={13} color="#dc2626" /></button>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
      <style>{`@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }`}</style>
    </main>
  );
}
